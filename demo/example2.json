{
  "version": "1.0",
  "ppt": {
    "theme": {
      "colors": {
        "primary": "#2563EB",
        "secondary": "#10B981",
        "danger": "#EF4444",
        "warning": "#F59E0B",
        "info": "#0EA5E9",
        "dark": "#0F172A",
        "muted": "#64748B"
      },
      "fonts": {
        "heading": "Microsoft YaHei",
        "body": "Microsoft YaHei Light"
      }
    },
    "size": {"width": 1920, "height": 1080, "unit": "px"},
    "defaultUnit": "px",
    "defaultLayout": "blank",
    "slides": [
      {
        "id": "cover_modern",
        "title": "现代封面",
        "background": {
          "gradient": {
            "type": "linear",
            "angle": 45,
            "stops": [
              {"position": 0, "color": "$primary"},
              {"position": 100, "color": "#1E3A8A"}
            ]
          }
        },
        "elements": [
          {
            "type": "group",
            "id": "cover_group",
            "elements": [
              {
                "type": "shape",
                "id": "accent_bar",
                "shapeType": "rect",
                "box": {"x": 0, "y": 0, "w": 8, "h": 100, "unit": "percent"},
                "fill": "$secondary",
                "shadow": {"x": 4, "y": 4, "blur": 6, "color": "#00000055"}
              },
              {
                "type": "text",
                "id": "hero_title",
                "box": {"x": 12, "y": 25, "w": 76, "h": 20, "unit": "percent"},
                "text": "JSON → PPTX 高级演示",
                "style": {"fontSize": 84, "color": "#FFFFFF", "bold": true, "fontFamily": "$heading", "valign": "middle", "align": "left"}
              },
              {
                "type": "text",
                "id": "hero_sub",
                "box": {"x": 12, "y": 46, "w": 60, "h": 8, "unit": "percent"},
                "text": "全面演示: 主题变量 / 渐变 / 组 / 图表 / 表格 / 超链接 / 视频占位 / SmartArt",
                "style": {"fontSize": 30, "color": "#E2E8F0", "fontFamily": "$body", "italic": true}
              },
              {
                "type": "shape",
                "id": "rotated_tag",
                "shapeType": "parallelogram",
                "box": {"x": 82, "y": 10, "w": 14, "h": 8, "unit": "percent"},
                "fill": "$warning",
                "rotation": 12,
                "border": {"color": "#FFFFFF", "width": 2},
                "shadow": {"x": 2, "y": 2, "blur": 4, "color": "#00000055"}
              },
              {
                "type": "text",
                "id": "tag_text",
                "box": {"x": 82, "y": 10, "w": 14, "h": 8, "unit": "percent"},
                "text": "DEMO",
                "style": {"fontSize": 40, "color": "#FFFFFF", "bold": true, "align": "center", "valign": "middle"}
              }
            ]
          },
          {
            "type": "image",
            "id": "logo_top",
            "box": {"x": 85, "y": 85, "w": 8, "h": 8, "unit": "percent"},
            "source": "base64:iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVQIW2P4////fwAJ+wP9L+Z2AAAAABJRU5ErkJggg==",
            "opacity": 0.7,
            "link": {"url": "https://github.com"}
          }
        ]
      },
      {
        "id": "typography_lists",
        "title": "排版与列表",
        "background": {"color": "#FFFFFF"},
        "elements": [
          {"type": "text", "id": "heading1", "box": {"x": 120, "y": 60, "w": 1680, "h": 80}, "text": "高级文本与列表特性", "style": {"fontSize": 54, "bold": true, "color": "$dark"}},
          {"type": "text", "id": "para_block", "box": {"x": 120, "y": 180, "w": 820, "h": 680},
            "style": {"fontSize": 22, "color": "$muted", "lineHeight": 1.2},
            "paragraphs": [
              {"text": "支持多段落+独立样式", "style": {"fontSize": 30, "bold": true, "color": "$primary"}},
              {"text": "普通段落展示主体内容。"},
              {"text": "自动编号列表项一", "listType": "number"},
              {"text": "自动编号列表项二", "listType": "number"},
              {"text": "自定义前缀编号三", "listType": "number", "number": 3, "numberPrefix": "3) "},
              {"text": "无序列表使用 bullet", "listType": "bullet"},
              {"text": "自定义符号", "bullet": true, "bulletChar": "»"},
              {"text": "层级缩进一级", "indent": 1},
              {"text": "层级缩进二级", "indent": 2, "style": {"color": "$secondary"}},
              {"text": "高亮文本，可更改字体族", "style": {"fontFamily": "$heading", "color": "$danger", "bold": true}},
              {"text": "下划线 / 斜体 / 组合", "style": {"italic": true, "underline": true, "color": "$info"}},
              {"text": "结束段"}
            ]
          },
          {"type": "shape", "id": "side_panel", "shapeType": "roundRect", "box": {"x": 1000, "y": 180, "w": 800, "h": 680}, "fill": "#F1F5F9", "shadow": {"x": 3, "y": 4, "blur": 8, "color": "#00000033"}},
          {"type": "text", "id": "panel_title", "box": {"x": 1020, "y": 200, "w": 760, "h": 80}, "text": "快速要点", "style": {"fontSize": 40, "color": "$primary", "bold": true}},
          {"type": "text", "id": "panel_list", "box": {"x": 1020, "y": 300, "w": 760, "h": 540},
            "paragraphs": [
              {"text": "✓ 支持主题色引用 ($primary)", "style": {"fontSize": 26, "color": "$secondary"}},
              {"text": "✓ 渐变背景 / 透明度 / 阴影", "style": {"fontSize": 26, "color": "$secondary"}},
              {"text": "✓ 列表与缩进", "style": {"fontSize": 26, "color": "$secondary"}},
              {"text": "✓ 百分比定位 & px 混用", "style": {"fontSize": 26, "color": "$secondary"}},
              {"text": "✓ 边框 + 旋转 + 超链接", "style": {"fontSize": 26, "color": "$secondary"}}
            ]
          }
        ]
      },
      {
        "id": "charts_showcase",
        "title": "多类型图表",
        "background": {"color": "#F8FAFC"},
        "elements": [
          {"type": "text", "id": "chart_heading", "box": {"x": 100, "y": 50, "w": 900, "h": 70}, "text": "图表类型与配置", "style": {"fontSize": 46, "bold": true, "color": "$dark"}},
          {"type": "chart", "id": "bar_basic", "chartType": "bar", "box": {"x": 100, "y": 150, "w": 600, "h": 350},
            "title": "柱状图", "data": {"categories": ["Jan", "Feb", "Mar", "Apr"], "series": [
              {"name": "新增用户", "values": [120, 180, 210, 260], "color": "$primary"},
              {"name": "活跃用户", "values": [90, 150, 190, 230], "color": "$secondary"}
            ]}, "chartOptions": {"legend": true, "dataLabels": false, "valueAxis": {"minimum": 0, "maximum": 300, "majorUnit": 50}}},
          {"type": "chart", "id": "line_smooth", "chartType": "lineSmooth", "box": {"x": 760, "y": 150, "w": 600, "h": 350},
            "title": "平滑折线", "data": {"categories": ["Q1", "Q2", "Q3", "Q4"], "series": [
              {"name": "转化率%", "values": [3.2, 3.8, 4.5, 5.1], "color": "$warning"}
            ]}, "chartOptions": {"legend": true, "dataLabels": true}},
          {"type": "chart", "id": "pie_demo", "chartType": "pie", "box": {"x": 1420, "y": 150, "w": 400, "h": 350},
            "title": "渠道占比", "data": {"categories": ["直销", "代理", "电商", "合作"], "series": [{"name": "份额", "values": [40, 25, 20, 15]}]}, "chartOptions": {"legend": true, "dataLabels": true}},
          {"type": "chart", "id": "stacked_bar", "chartType": "barStacked", "box": {"x": 100, "y": 540, "w": 900, "h": 400},
            "title": "堆叠收入构成", "data": {"categories": ["2022", "2023", "2024"], "series": [
              {"name": "订阅", "values": [320, 410, 520], "color": "$primary"},
              {"name": "增值", "values": [120, 180, 260], "color": "$secondary"},
              {"name": "服务", "values": [80, 90, 120], "color": "$info"}
            ]}, "chartOptions": {"legend": true, "dataLabels": true}},
          {"type": "chart", "id": "area_chart", "chartType": "area", "box": {"x": 1040, "y": 540, "w": 780, "h": 400},
            "title": "流量趋势", "data": {"categories": ["00:00", "06:00", "12:00", "18:00", "24:00"], "series": [
              {"name": "PV", "values": [1000, 3400, 8800, 7600, 4200], "color": "$secondary"}
            ]}, "chartOptions": {"legend": false, "dataLabels": false}}
        ]
      },
      {
        "id": "xy_bubble_radar",
        "title": "散点/气泡/雷达",
        "background": {"color": "#FFFFFF"},
        "elements": [
          {"type": "text", "id": "advanced_charts_title", "box": {"x": 100, "y": 60, "w": 1720, "h": 70}, "text": "高级图表类型", "style": {"fontSize": 48, "bold": true, "color": "$dark", "align": "center"}},
          {"type": "chart", "id": "scatter_chart", "chartType": "scatter", "box": {"x": 100, "y": 170, "w": 600, "h": 380},
            "title": "散点相关性", "data": {"series": [
              {"name": "A/B测试", "values": [[1,2],[2,2.2],[3,3.1],[4,3.9],[5,5.2]]}
            ]}},
          {"type": "chart", "id": "bubble_chart", "chartType": "bubble", "box": {"x": 760, "y": 170, "w": 600, "h": 380},
            "title": "气泡分布", "data": {"series": [
              {"name": "市场规模", "values": [[1,2,10],[2,2.5,20],[3,3.2,15],[4,4.1,25]]}
            ]}},
          {"type": "chart", "id": "radar_chart", "chartType": "radar", "box": {"x": 1420, "y": 170, "w": 400, "h": 380},
            "title": "能力雷达", "data": {"categories": ["性能", "易用", "安全", "扩展", "支持"], "series": [
              {"name": "方案A", "values": [80,90,85,70,88]},
              {"name": "方案B", "values": [75,82,92,65,80]}
            ]}, "chartOptions": {"legend": true}},
          {"type": "text", "id": "note_text", "box": {"x": 100, "y": 580, "w": 1720, "h": 380},
            "paragraphs": [
              {"text": "使用 scatter / bubble / radar 展示更丰富的可视化形式", "style": {"fontSize": 30, "color": "$primary", "bold": true}},
              {"text": "散点: XY 数值对; 气泡: (x,y,size); 雷达: 多维评分", "style": {"fontSize": 24, "color": "$muted"}}
            ]}
        ]
      },
      {
        "id": "data_table_demo",
        "title": "表格与样式",
        "background": {"color": "#F1F5F9"},
        "elements": [
          {"type": "text", "id": "table_title", "box": {"x": 100, "y": 60, "w": 1000, "h": 70}, "text": "表格展示: 头/行带条纹 + 居中 + 主题色", "style": {"fontSize": 42, "bold": true, "color": "$dark"}},
          {"type": "table", "id": "styled_table", "box": {"x": 100, "y": 160, "w": 1720, "h": 520},
            "table": {"header": ["指标", "Q1", "Q2", "Q3", "Q4", "全年"],
              "rows": [
                ["营收(百万)", "320", "380", "420", "500", "1620"],
                ["成本(百万)", "140", "160", "170", "210", "680"],
                ["毛利率%", "56.2%", "57.9%", "59.5%", "58.0%", "57.9%"],
                ["新增用户(万)", "12", "15", "18", "22", "67"],
                ["付费转化%", "3.2%", "3.6%", "3.9%", "4.4%", "3.8%"]
              ],
              "columnWidths": [240, 200, 200, 200, 200, 260],
              "style": {
                "header": {"fill": "$primary", "color": "#FFFFFF", "fontSize": 20, "bold": true, "align": "center", "valign": "middle"},
                "body": {"fontSize": 18, "color": "$dark", "align": "center", "valign": "middle"}
              },
              "bandedRows": true
            }
          },
          {"type": "text", "id": "table_note", "box": {"x": 100, "y": 720, "w": 1720, "h": 300},
            "paragraphs": [
              {"text": "表格支持: 自定义列宽 / 主题色 / 头部和主体样式 / 条纹行", "style": {"fontSize": 28, "color": "$secondary"}}
            ]}
        ]
      },
      {
        "id": "shapes_icons_lines",
        "title": "形状/图标/线条",
        "background": {"color": "#FFFFFF"},
        "elements": [
          {"type": "text", "id": "shape_hdr", "box": {"x": 100, "y": 60, "w": 1000, "h": 70}, "text": "形状 + 阴影 + 渐变 + 线条 + 图标占位", "style": {"fontSize": 44, "bold": true, "color": "$dark"}},
          {"type": "shape", "id": "gradient_shape", "shapeType": "rect", "box": {"x": 100, "y": 180, "w": 400, "h": 260},
            "gradient": {"type": "linear", "angle": 90, "stops": [{"position": 0, "color": "$primary"}, {"position": 100, "color": "$info"}]},
            "border": {"color": "#FFFFFF", "width": 4}, "shadow": {"x": 6, "y": 6, "blur": 10, "color": "#00000055"}},
          {"type": "shape", "id": "circle_shape", "shapeType": "circle", "box": {"x": 540, "y": 180, "w": 260, "h": 260}, "fill": "$secondary", "opacity": 0.85},
          {"type": "icon", "id": "icon_demo", "box": {"x": 560, "y": 200, "w": 220, "h": 220}, "color": "$warning", "shadow": {"x": 2, "y": 4, "blur": 6, "color": "#00000033"}},
          {"type": "shape", "id": "star_shape", "shapeType": "star5", "box": {"x": 860, "y": 180, "w": 300, "h": 300}, "fill": "$warning", "rotation": 15, "border": {"color": "#FFFFFF", "width": 3}},
          {"type": "line", "id": "connector_line", "points": [{"x": 1200, "y": 180}, {"x": 1500, "y": 300}], "stroke": "$danger", "strokeWidth": 4, "strokeStyle": "dashed"},
          {"type": "text", "id": "shape_note", "box": {"x": 100, "y": 480, "w": 1720, "h": 500},
            "paragraphs": [
              {"text": "形状支持: 多类型 / 渐变 / 边框 / 透明度 / 旋转 / 阴影", "style": {"fontSize": 30, "color": "$primary", "bold": true}},
              {"text": "线条(Connector) 支持 颜色 / 粗细 / 虚线", "style": {"fontSize": 24, "color": "$muted"}}
            ]}
        ]
      },
      {
        "id": "media_and_smartart",
        "title": "视频占位与SmartArt模拟",
        "background": {"color": "#0F172A"},
        "elements": [
          {"type": "text", "id": "media_title", "box": {"x": 100, "y": 60, "w": 1720, "h": 80}, "text": "媒体与流程", "style": {"fontSize": 52, "color": "#FFFFFF", "bold": true, "align": "center"}},
          {"type": "video", "id": "video_placeholder", "box": {"x": 150, "y": 180, "w": 780, "h": 440}, "border": {"color": "#FFFFFF", "width": 3}},
          {"type": "smartArt", "id": "process_flow", "smartArtType": "process", "box": {"x": 1050, "y": 180, "w": 720, "h": 500},
            "nodes": [
              {"text": "采集", "color": "$primary"},
              {"text": "清洗", "color": "$secondary"},
              {"text": "建模", "color": "$warning"},
              {"text": "部署", "color": "$danger"},
              {"text": "监控", "color": "$info"}
            ]},
          {"type": "text", "id": "media_desc", "box": {"x": 150, "y": 660, "w": 1620, "h": 360},
            "paragraphs": [
              {"text": "视频: 目前为占位实现 (黑色矩形 + 标注)", "style": {"fontSize": 26, "color": "#E2E8F0"}},
              {"text": "SmartArt: 采用形状模拟流程/列表 (可扩展)", "style": {"fontSize": 26, "color": "#E2E8F0"}}
            ]}
        ]
      },
      {
        "id": "hyperlink_demo",
        "title": "超链接交互",
        "background": {"color": "#FFFFFF"},
        "elements": [
          {"type": "text", "id": "link_title", "box": {"x": 100, "y": 80, "w": 1720, "h": 100}, "text": "超链接与内部导航 (示例)", "style": {"fontSize": 50, "bold": true, "color": "$dark", "align": "center"}},
          {"type": "shape", "id": "link_btn_github", "shapeType": "roundRect", "box": {"x": 400, "y": 260, "w": 360, "h": 160}, "fill": "$primary", "shadow": {"x": 2, "y": 4, "blur": 6, "color": "#00000055"}},
          {"type": "text", "id": "link_btn_github_label", "box": {"x": 400, "y": 260, "w": 360, "h": 160}, "text": "GitHub", "style": {"fontSize": 46, "color": "#FFFFFF", "bold": true, "align": "center", "valign": "middle"}, "link": {"url": "https://github.com"}},
          {"type": "shape", "id": "link_btn_doc", "shapeType": "roundRect", "box": {"x": 800, "y": 260, "w": 360, "h": 160}, "fill": "$secondary"},
            {"type": "text", "id": "link_btn_doc_label", "box": {"x": 800, "y": 260, "w": 360, "h": 160}, "text": "产品文档", "style": {"fontSize": 46, "color": "#FFFFFF", "bold": true, "align": "center", "valign": "middle"}, "link": {"url": "https://example.com/docs"}},
          {"type": "shape", "id": "link_btn_blog", "shapeType": "roundRect", "box": {"x": 1200, "y": 260, "w": 360, "h": 160}, "fill": "$warning"},
          {"type": "text", "id": "link_btn_blog_label", "box": {"x": 1200, "y": 260, "w": 360, "h": 160}, "text": "博客", "style": {"fontSize": 46, "color": "#FFFFFF", "bold": true, "align": "center", "valign": "middle"}, "link": {"url": "https://example.com/blog"}},
          {"type": "text", "id": "link_note", "box": {"x": 100, "y": 520, "w": 1720, "h": 400}, "paragraphs": [
            {"text": "shape 或 text 元素可附加 link.url 实现外部跳转", "style": {"fontSize": 30, "color": "$primary", "bold": true}},
            {"text": "内部跳转 slideId 预留 (未实现)", "style": {"fontSize": 24, "color": "$muted"}}
          ]}
        ]
      },
      {
        "id": "ending_modern",
        "title": "结束页",
        "background": {"color": "#0F172A"},
        "elements": [
          {"type": "text", "id": "thanks", "box": {"x": 50, "y": 30, "w": 90, "h": 30, "unit": "percent"}, "text": "THANK YOU / 谢谢", "style": {"fontSize": 80, "color": "#FFFFFF", "bold": true, "align": "center", "valign": "middle"}},
          {"type": "shape", "id": "end_bar", "shapeType": "rect", "box": {"x": 20, "y": 65, "w": 60, "h": 1, "unit": "percent"}, "fill": "$primary"},
          {"type": "text", "id": "contact_block", "box": {"x": 50, "y": 70, "w": 90, "h": 20, "unit": "percent"}, "paragraphs": [
            {"text": "📧 team@example.com", "style": {"fontSize": 30, "color": "#E2E8F0", "align": "center"}},
            {"text": "🌐 https://example.com", "style": {"fontSize": 30, "color": "#E2E8F0", "align": "center"}}
          ]}
        ]
      }
    ]
  }
}
