{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/ppt-enhanced.schema.json",
  "title": "Enhanced PowerPoint Deck Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["ppt"],
  "properties": {
    "version": {
      "type": "string"
    },
    "ppt": {
      "$ref": "#/$defs/ppt"
    }
  },
  "$defs": {
    "ppt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slides"],
      "properties": {
        "size": {
          "$ref": "#/$defs/size"
        },
        "defaultUnit": {
          "$ref": "#/$defs/unit"
        },
        "defaultLayout": {
          "$ref": "#/$defs/layoutRef"
        },
        "theme": {
          "$ref": "#/$defs/theme"
        },
        "slides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/slide"
          }
        }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "colors": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/colorValue"
          }
        },
        "fonts": {
          "type": "object",
          "properties": {
            "heading": {
              "type": "string"
            },
            "body": {
              "type": "string"
            }
          }
        },
        "spacing": {
          "type": "object",
          "properties": {
            "small": {"type": "number"},
            "medium": {"type": "number"},
            "large": {"type": "number"}
          }
        }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "enum": ["px"]
        }
      }
    },
    "unit": {
      "type": "string",
      "enum": ["px", "percent"]
    },
    "layoutRef": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "slide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["elements"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "layout": {
          "$ref": "#/$defs/layoutRef"
        },
        "background": {
          "$ref": "#/$defs/background"
        },
        "transition": {
          "$ref": "#/$defs/transition"
        },
        "elements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/element"
          }
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "fade", "slide", "wipe", "zoom", "flip"]
        },
        "duration": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "background": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "color": {
          "$ref": "#/$defs/colorValue"
        },
        "gradient": {
          "$ref": "#/$defs/gradient"
        },
        "image": {
          "$ref": "#/$defs/backgroundImage"
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "backgroundImage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["src"],
      "properties": {
        "src": {
          "$ref": "#/$defs/imageSource"
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "blur": {
          "type": "number",
          "minimum": 0
        },
        "filter": {
          "type": "string",
          "enum": ["none", "grayscale", "sepia", "brightness", "contrast", "blur"]
        }
      }
    },
    "element": {
      "oneOf": [
        {"$ref": "#/$defs/textElement"},
        {"$ref": "#/$defs/imageElement"},
        {"$ref": "#/$defs/shapeElement"},
        {"$ref": "#/$defs/chartElement"},
        {"$ref": "#/$defs/tableElement"},
        {"$ref": "#/$defs/iconElement"},
        {"$ref": "#/$defs/groupElement"},
        {"$ref": "#/$defs/lineElement"},
        {"$ref": "#/$defs/videoElement"},
        {"$ref": "#/$defs/smartArtElement"}
      ]
    },
    "baseElement": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "box": {"$ref": "#/$defs/box"},
        "zIndex": {"type": "integer"},
        "rotation": {"type": "number"},
        "opacity": {"type": "number", "minimum": 0, "maximum": 1},
        "shadow": {"$ref": "#/$defs/shadow"},
        "animation": {"$ref": "#/$defs/animation"},
        "link": {"$ref": "#/$defs/hyperlink"}
      }
    },
    "box": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {"type": "number"},
        "y": {"type": "number"},
        "w": {"type": "number", "minimum": 0},
        "h": {"type": "number", "minimum": 0},
        "unit": {"$ref": "#/$defs/unit"}
      }
    },
    "shadow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {"type": "number"},
        "y": {"type": "number"},
        "blur": {"type": "number", "minimum": 0},
        "spread": {"type": "number"},
        "color": {"$ref": "#/$defs/colorValue"},
        "inset": {"type": "boolean"}
      }
    },
    "animation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entrance": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["none", "fade", "slideIn", "zoom", "wipe", "float", "bounce", "rotate"]
            },
            "direction": {
              "type": "string",
              "enum": ["top", "bottom", "left", "right", "center"]
            },
            "duration": {"type": "number", "minimum": 0},
            "delay": {"type": "number", "minimum": 0},
            "order": {"type": "integer", "minimum": 0}
          }
        },
        "emphasis": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["none", "pulse", "grow", "spin", "shake", "flash"]
            },
            "duration": {"type": "number", "minimum": 0},
            "repeat": {"type": "integer", "minimum": 0}
          }
        },
        "exit": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["none", "fade", "slideOut", "zoom", "wipe"]
            },
            "direction": {
              "type": "string",
              "enum": ["top", "bottom", "left", "right"]
            },
            "duration": {"type": "number", "minimum": 0}
          }
        }
      }
    },
    "hyperlink": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {"type": "string"},
        "slideId": {"type": "string"},
        "tooltip": {"type": "string"}
      }
    },
    "border": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": {"type": "number", "minimum": 0},
        "color": {"$ref": "#/$defs/colorValue"},
        "style": {
          "type": "string",
          "enum": ["none", "solid", "dashed", "dotted", "double"]
        },
        "radius": {
          "oneOf": [
            {"type": "number", "minimum": 0},
            {
              "type": "object",
              "properties": {
                "topLeft": {"type": "number", "minimum": 0},
                "topRight": {"type": "number", "minimum": 0},
                "bottomLeft": {"type": "number", "minimum": 0},
                "bottomRight": {"type": "number", "minimum": 0}
              }
            }
          ]
        }
      }
    },
    "textStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fontSize": {"type": "number", "minimum": 0},
        "color": {"$ref": "#/$defs/colorValue"},
        "align": {
          "type": "string",
          "enum": ["left", "center", "right", "justify"]
        },
        "valign": {
          "type": "string",
          "enum": ["top", "middle", "bottom"]
        },
        "bold": {"type": "boolean"},
        "italic": {"type": "boolean"},
        "underline": {"type": "boolean"},
        "strikethrough": {"type": "boolean"},
        "fontFamily": {"type": "string", "minLength": 1},
        "lineHeight": {"type": "number", "minimum": 0},
        "letterSpacing": {"type": "number"},
        "textShadow": {"$ref": "#/$defs/shadow"},
        "backgroundColor": {"$ref": "#/$defs/colorValue"},
        "level": {"type": "integer", "minimum": 0}
      }
    },
    "textParagraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {"type": "string"},
        "style": {"$ref": "#/$defs/textStyle"},
        "listType": {
          "type": "string",
          "enum": ["bullet", "number"]
        },
        "bullet": {"type": "boolean"},
        "bulletChar": {"type": "string", "minLength": 1, "maxLength": 5},
        "number": {"type": "integer", "minimum": 1},
        "numberPrefix": {"type": "string", "maxLength": 20},
        "indent": {"type": "number", "minimum": 0}
      }
    },
    "textElement": {
      "allOf": [
        {"$ref": "#/$defs/baseElement"},
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {"const": "text"},
            "text": {"type": "string"},
            "style": {"$ref": "#/$defs/textStyle"},
            "paragraphs": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/textParagraph"}
            },
            "border": {"$ref": "#/$defs/border"},
            "fill": {"$ref": "#/$defs/colorValue"},
            "padding": {
              "oneOf": [
                {"type": "number", "minimum": 0},
                {
                  "type": "object",
                  "properties": {
                    "top": {"type": "number", "minimum": 0},
                    "right": {"type": "number", "minimum": 0},
                    "bottom": {"type": "number", "minimum": 0},
                    "left": {"type": "number", "minimum": 0}
                  }
                }
              ]
            }
          },
          "anyOf": [
            {"required": ["text"]},
            {"required": ["paragraphs"]}
          ]
        }
      ]
    },
    "imageElement": {
      "allOf": [
        {"$ref": "#/$defs/baseElement"},
        {
          "type": "object",
          "required": ["type", "source"],
          "properties": {
            "type": {"const": "image"},
            "source": {"$ref": "#/$defs/imageSource"},
            "crop": {
              "type": "object",
              "properties": {
                "x": {"type": "number"},
                "y": {"type": "number"},
                "w": {"type": "number", "minimum": 0},
                "h": {"type": "number", "minimum": 0}
              }
            },
            "filter": {
              "type": "string",
              "enum": ["none", "grayscale", "sepia", "brightness", "contrast", "saturate", "blur", "hueRotate", "invert"]
            },
            "filterValue": {"type": "number"},
            "border": {"$ref": "#/$defs/border"},
            "objectFit": {
              "type": "string",
              "enum": ["fill", "contain", "cover", "none", "scale-down"]
            }
          }
        }
      ]
    },
    "shapeElement": {
      "allOf": [
        {"$ref": "#/$defs/baseElement"},
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {"const": "shape"},
            "shapeType": {
              "type": "string",
              "enum": [
                "rect", "roundRect", "ellipse", "circle",
                "triangle", "rightTriangle", "pentagon", "hexagon", "octagon",
                "star", "star5", "star6", "star8",
                "arrow", "arrowLeft", "arrowRight", "arrowUp", "arrowDown",
                "arrowBoth", "chevron", "chevronLeft", "chevronRight",
                "callout", "calloutRound", "cloud", "heart", "diamond",
                "parallelogram", "trapezoid", "cross", "plus"
              ]
            },
            "fill": {"$ref": "#/$defs/colorValue"},
            "gradient": {"$ref": "#/$defs/gradient"},
            "border": {"$ref": "#/$defs/border"},
            "backdropBlur": {"type": "number", "minimum": 0}
          }
        }
      ]
    },
    "iconElement": {
      "allOf": [
        {"$ref": "#/$defs/baseElement"},
        {
          "type": "object",
          "required": ["type", "icon"],
          "properties": {
            "type": {"const": "icon"},
            "icon": {
              "oneOf": [
                {
                  "type": "object",
                  "required": ["library", "name"],
                  "properties": {
                    "library": {
                      "type": "string",
                      "enum": ["fontawesome", "material", "lucide", "heroicons", "bootstrap", "custom"]
                    },
                    "name": {"type": "string"},
                    "style": {
                      "type": "string",
                      "enum": ["solid", "regular", "light", "duotone", "outline", "filled"]
                    }
                  }
                },
                {
                  "type": "object",
                  "required": ["svg"],
                  "properties": {
                    "svg": {"type": "string"}
                  }
                }
              ]
            },
            "size": {"type": "number", "minimum": 0},
            "color": {"$ref": "#/$defs/colorValue"},
            "gradient": {"$ref": "#/$defs/gradient"},
            "strokeWidth": {"type": "number", "minimum": 0}
          }
        }
      ]
    },
    "lineElement": {
      "allOf": [
        {"$ref": "#/$defs/baseElement"},
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {"const": "line"},
            "points": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "properties": {
                  "x": {"type": "number"},
                  "y": {"type": "number"}
                }
              }
            },
            "stroke": {"$ref": "#/$defs/colorValue"},
            "strokeWidth": {"type": "number", "minimum": 0},
            "strokeStyle": {
              "type": "string",
              "enum": ["solid", "dashed", "dotted"]
            },
            "startArrow": {
              "type": "string",
              "enum": ["none", "arrow", "circle", "diamond", "square"]
            },
            "endArrow": {
              "type": "string",
              "enum": ["none", "arrow", "circle", "diamond", "square"]
            },
            "curved": {"type": "boolean"}
          }
        }
      ]
    },
    "groupElement": {
      "allOf": [
        {"$ref": "#/$defs/baseElement"},
        {
          "type": "object",
          "required": ["type", "elements"],
          "properties": {
            "type": {"const": "group"},
            "elements": {
              "type": "array",
              "items": {"$ref": "#/$defs/element"}
            },
            "transform": {
              "type": "object",
              "properties": {
                "rotate": {"type": "number"},
                "scale": {"type": "number", "minimum": 0},
                "scaleX": {"type": "number"},
                "scaleY": {"type": "number"},
                "skewX": {"type": "number"},
                "skewY": {"type": "number"}
              }
            }
          }
        }
      ]
    },
    "chartElement": {
      "allOf": [
        {"$ref": "#/$defs/baseElement"},
        {
          "type": "object",
          "required": ["type", "data"],
          "properties": {
            "type": {"const": "chart"},
            "chartType": {
              "type": "string",
              "enum": [
                "bar", "barStacked", "barStacked100", "barHorizontal",
                "line", "lineSmooth", "area", "areaStacked",
                "pie", "doughnut", "radar", "polarArea",
                "scatter", "bubble", "funnel", "gauge", "waterfall"
              ]
            },
            "title": {"type": "string"},
            "data": {"$ref": "#/$defs/chartData"},
            "chartOptions": {"$ref": "#/$defs/chartOptions"}
          }
        }
      ]
    },
    "chartOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "legend": {
          "oneOf": [
            {"type": "boolean"},
            {
              "type": "object",
              "properties": {
                "show": {"type": "boolean"},
                "position": {
                  "type": "string",
                  "enum": ["top", "bottom", "left", "right"]
                }
              }
            }
          ]
        },
        "dataLabels": {
          "oneOf": [
            {"type": "boolean"},
            {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean"},
                "position": {
                  "type": "string",
                  "enum": ["top", "center", "bottom", "inside", "outside"]
                },
                "format": {"type": "string"}
              }
            }
          ]
        },
        "grid": {
          "type": "object",
          "properties": {
            "show": {"type": "boolean"},
            "color": {"$ref": "#/$defs/colorValue"},
            "strokeStyle": {
              "type": "string",
              "enum": ["solid", "dashed", "dotted"]
            }
          }
        },
        "valueAxis": {
          "type": "object",
          "properties": {
            "minimum": {"type": "number"},
            "maximum": {"type": "number"},
            "majorUnit": {"type": "number", "exclusiveMinimum": 0},
            "title": {"type": "string"},
            "format": {"type": "string"}
          }
        },
        "categoryAxis": {
          "type": "object",
          "properties": {
            "tickLabelRotation": {"type": "number"},
            "title": {"type": "string"}
          }
        },
        "colors": {
          "type": "array",
          "items": {"$ref": "#/$defs/colorValue"}
        },
        "tooltip": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "format": {"type": "string"}
          }
        }
      }
    },
    "chartData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categories", "series"],
      "properties": {
        "categories": {
          "type": "array",
          "items": {"type": "string"}
        },
        "series": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/chartSeries"}
        }
      }
    },
    "chartSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["values"],
      "properties": {
        "name": {"type": "string"},
        "values": {
          "type": "array",
          "items": {"type": "number"}
        },
        "color": {"$ref": "#/$defs/colorValue"},
        "gradient": {"$ref": "#/$defs/gradient"},
        "type": {
          "type": "string",
          "enum": ["line", "bar", "area"]
        }
      }
    },
    "tableElement": {
      "allOf": [
        {"$ref": "#/$defs/baseElement"},
        {
          "type": "object",
          "required": ["type", "table"],
          "properties": {
            "type": {"const": "table"},
            "table": {"$ref": "#/$defs/tableSpec"}
          }
        }
      ]
    },
    "tableSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rows"],
      "properties": {
        "header": {
          "type": "array",
          "items": {"type": "string"}
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {"$ref": "#/$defs/cellValue"}
          }
        },
        "columnWidths": {
          "type": "array",
          "items": {"type": "number", "minimum": 0}
        },
        "columnWidthsUnit": {"$ref": "#/$defs/unit"},
        "bandedRows": {"type": "boolean"},
        "bandedColumns": {"type": "boolean"},
        "style": {"$ref": "#/$defs/tableStyle"},
        "border": {"$ref": "#/$defs/border"}
      }
    },
    "tableStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fontSize": {"type": "number", "minimum": 0},
        "color": {"$ref": "#/$defs/colorValue"},
        "align": {
          "type": "string",
          "enum": ["left", "center", "right"]
        },
        "valign": {
          "type": "string",
          "enum": ["top", "middle", "bottom"]
        },
        "bold": {"type": "boolean"},
        "italic": {"type": "boolean"},
        "fontFamily": {"type": "string", "minLength": 1},
        "fill": {"$ref": "#/$defs/colorValue"},
        "padding": {"type": "number", "minimum": 0},
        "header": {"$ref": "#/$defs/tableCellStyle"},
        "body": {"$ref": "#/$defs/tableCellStyle"},
        "footer": {"$ref": "#/$defs/tableCellStyle"}
      }
    },
    "tableCellStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fontSize": {"type": "number", "minimum": 0},
        "color": {"$ref": "#/$defs/colorValue"},
        "align": {
          "type": "string",
          "enum": ["left", "center", "right"]
        },
        "valign": {
          "type": "string",
          "enum": ["top", "middle", "bottom"]
        },
        "bold": {"type": "boolean"},
        "italic": {"type": "boolean"},
        "fontFamily": {"type": "string", "minLength": 1},
        "fill": {"$ref": "#/$defs/colorValue"},
        "gradient": {"$ref": "#/$defs/gradient"},
        "border": {"$ref": "#/$defs/border"}
      }
    },
    "videoElement": {
      "allOf": [
        {"$ref": "#/$defs/baseElement"},
        {
          "type": "object",
          "required": ["type", "source"],
          "properties": {
            "type": {"const": "video"},
            "source": {"type": "string"},
            "poster": {"$ref": "#/$defs/imageSource"},
            "autoplay": {"type": "boolean"},
            "loop": {"type": "boolean"},
            "muted": {"type": "boolean"},
            "controls": {"type": "boolean"},
            "border": {"$ref": "#/$defs/border"}
          }
        }
      ]
    },
    "smartArtElement": {
      "allOf": [
        {"$ref": "#/$defs/baseElement"},
        {
          "type": "object",
          "required": ["type", "smartArtType", "nodes"],
          "properties": {
            "type": {"const": "smartArt"},
            "smartArtType": {
              "type": "string",
              "enum": [
                "list", "process", "cycle", "hierarchy",
                "relationship", "matrix", "pyramid", "funnel",
                "venn", "timeline", "organizationChart"
              ]
            },
            "nodes": {
              "type": "array",
              "items": {"$ref": "#/$defs/smartArtNode"}
            },
            "layout": {
              "type": "string",
              "enum": ["horizontal", "vertical", "circular", "radial"]
            },
            "style": {"$ref": "#/$defs/smartArtStyle"}
          }
        }
      ]
    },
    "smartArtNode": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "text": {"type": "string"},
        "icon": {"type": "string"},
        "color": {"$ref": "#/$defs/colorValue"},
        "children": {
          "type": "array",
          "items": {"$ref": "#/$defs/smartArtNode"}
        },
        "data": {"type": "object"}
      }
    },
    "smartArtStyle": {
      "type": "object",
      "properties": {
        "nodeShape": {
          "type": "string",
          "enum": ["rect", "circle", "roundRect", "hexagon"]
        },
        "nodeColor": {"$ref": "#/$defs/colorValue"},
        "nodeGradient": {"$ref": "#/$defs/gradient"},
        "connectorStyle": {
          "type": "string",
          "enum": ["line", "arrow", "curved"]
        },
        "connectorColor": {"$ref": "#/$defs/colorValue"},
        "spacing": {"type": "number", "minimum": 0}
      }
    },
    "gradient": {
      "type": "object",
      "required": ["type", "stops"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["linear", "radial", "conic"]
        },
        "angle": {"type": "number"},
        "stops": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["color", "position"],
            "properties": {
              "color": {"$ref": "#/$defs/colorValue"},
              "position": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            }
          }
        }
      }
    },
    "colorValue": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$"
        },
        {
          "type": "string",
          "pattern": "^rgba?\\("
        },
        {
          "type": "string",
          "pattern": "^hsla?\\("
        },
        {
          "type": "string",
          "pattern": "^\\$[a-zA-Z][a-zA-Z0-9_-]*$"
        }
      ]
    },
    "cellValue": {
      "type": ["string", "number", "boolean", "null"]
    },
    "imageSource": {
      "type": "string",
      "pattern": "^(?:base64|url|file):.+"
    },
    "color": {
      "type": "string",
      "pattern": "^#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
    }
  }
}